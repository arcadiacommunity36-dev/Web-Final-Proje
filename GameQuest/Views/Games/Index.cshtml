@model List<GameQuest.Models.Game>

@{
    ViewData["Title"] = "Oyunlar";
    var categories = ViewBag.Categories as List<GameQuest.Models.Category> ?? new();
    string? q = ViewBag.Query as string;
    int? selectedCategoryId = ViewBag.SelectedCategoryId as int?;
}

<div class="py-4">
    <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">Oyunlar</h1>
            <div class="text-muted">Kategori seçerek filtreleyebilir, isimle arayabilirsin.</div>
        </div>
    </div>

    <form method="get" class="row g-2 align-items-end mb-4">
        <div class="col-12 col-md-5">
            <label class="form-label">Arama</label>
            <input name="q" value="@q" class="form-control" placeholder="Örn: Valorant, LoL, CS..." />
        </div>
        <div class="col-12 col-md-4">
            <label class="form-label">Kategori</label>
            <select name="categoryId" class="form-select">
                <option value="">Tümü</option>
                @foreach (var c in categories)
                {
                    <option value="@c.Id" selected="@(selectedCategoryId == c.Id)">@c.Name</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-3 d-flex gap-2">
            <button class="btn btn-gq w-100" type="submit">Filtrele</button>
            <a class="btn btn-outline-light w-100" asp-action="Index">Sıfırla</a>
        </div>
    </form>

    @if (Model.Count == 0)
    {
        <div class="alert alert-dark border">
            Sonuç bulunamadı.
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var game in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <a class="text-decoration-none" asp-action="Details" asp-route-id="@game.Id">
                        <div class="card gq-surface h-100">
                            @if (!string.IsNullOrWhiteSpace(game.ImageUrl))
                            {
                                <img src="@game.ImageUrl" class="card-img-top" alt="@game.Name" style="object-fit: cover; height: 180px;" />
                            }
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div>
                                        <div class="fw-semibold">@game.Name</div>
                                        <div class="small text-muted">@game.Category?.Name</div>
                                    </div>
                                    <span class="badge text-bg-secondary">Detay</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>

