@model List<GameQuest.Models.Category>

@{
    ViewData["Title"] = "Kategori Yönetimi";
}

<div class="py-4">
    <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">Kategoriler</h1>
            <div class="text-muted">Kategori ekle/düzenle/sil.</div>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-light" asp-action="Index">Admin</a>
            <a class="btn btn-gq" asp-action="CreateCategory">Kategori Ekle</a>
        </div>
    </div>

    <div class="card gq-surface">
        <div class="card-body">
            @if (Model.Count == 0)
            {
                <div class="text-muted">Henüz kategori yok.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Kategori</th>
                                <th>Durum</th>
                                <th class="text-end" style="width: 220px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@c.Name</td>
                                    <td>
                                        @if (c.IsActive)
                                        {
                                            <span class="badge text-bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary">Pasif</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-light" asp-action="EditCategory" asp-route-id="@c.Id">Düzenle</a>
                                        <form asp-action="DeleteCategory" asp-route-id="@c.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Silmek istediğine emin misin?')">Sil</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

