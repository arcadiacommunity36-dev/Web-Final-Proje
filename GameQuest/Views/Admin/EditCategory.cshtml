@model GameQuest.ViewModels.AdminCategoryEditViewModel

@{
    ViewData["Title"] = "Kategori Düzenle";
}

<div class="py-4">
    <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">Kategori Düzenle</h1>
            <div class="text-muted">Kategori bilgilerini güncelle.</div>
        </div>
        <a class="btn btn-outline-light" asp-action="Categories">Geri</a>
    </div>

    <div class="card gq-surface">
        <div class="card-body">
            <form method="post" class="row g-3">
                @Html.AntiForgeryToken()

                <div class="col-12">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="IsActive" />
                        <label class="form-check-label" asp-for="IsActive"></label>
                    </div>
                    <span asp-validation-for="IsActive" class="text-danger"></span>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button class="btn btn-gq" type="submit">Kaydet</button>
                    <a class="btn btn-outline-light" asp-action="Categories">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

