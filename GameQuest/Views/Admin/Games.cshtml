@model List<GameQuest.Models.Game>

@{
    ViewData["Title"] = "Oyun Yönetimi";
}

<div class="py-4">
    <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">Oyunlar</h1>
            <div class="text-muted">Oyun ekle/düzenle/sil.</div>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-light" asp-action="Index">Admin</a>
            <a class="btn btn-gq" asp-action="CreateGame">Oyun Ekle</a>
        </div>
    </div>

    <div class="card gq-surface">
        <div class="card-body">
            @if (Model.Count == 0)
            {
                <div class="text-muted">Henüz oyun yok.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Oyun</th>
                                <th>Kategori</th>
                                <th class="text-end" style="width: 220px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var g in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@g.Name</td>
                                    <td class="text-muted">@g.Category?.Name</td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-light" asp-action="EditGame" asp-route-id="@g.Id">Düzenle</a>
                                        <form asp-action="DeleteGame" asp-route-id="@g.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Silmek istediğine emin misin?')">Sil</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

