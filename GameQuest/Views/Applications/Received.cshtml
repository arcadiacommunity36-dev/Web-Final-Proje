@model List<GameQuest.Models.Application>

@{
    ViewData["Title"] = "Gelen Başvurular";
}

<div class="py-4">
    <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">Gelen Başvurular</h1>
            <div class="text-muted">İlanlarına gelen başvuruların listesi.</div>
        </div>
        <a class="btn btn-outline-light" asp-controller="Adverts" asp-action="Create">Yeni ilan aç</a>
    </div>

    <div class="card gq-surface">
        <div class="card-body">
            @if (Model.Count == 0)
            {
                <div class="text-muted">Henüz ilanlarına gelen başvuru yok.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>İlan</th>
                                <th>Oyun</th>
                                <th>Başvuran</th>
                                <th>Tarih</th>
                                <th>Mesaj</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Adverts" asp-action="Details" asp-route-id="@a.AdvertId" class="text-decoration-none">
                                            @a.Advert?.Title
                                        </a>
                                    </td>
                                    <td class="text-muted">@a.Advert?.Game?.Name</td>
                                    <td class="text-muted">@a.Applicant?.Username</td>
                                    <td class="text-muted">@a.AppliedAt.ToString("dd.MM.yyyy")</td>
                                    <td class="text-muted">@(!string.IsNullOrWhiteSpace(a.Message) ? a.Message : "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

